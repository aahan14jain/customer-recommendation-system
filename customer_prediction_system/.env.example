# Copy to .env and adjust. Django loads credentials via the environment (export or your process manager).
# PostgreSQL — used for django.contrib.auth, sessions, JWT blacklist, and predictor (Customer, Transaction, UserProfile).

POSTGRES_DB=customer_prediction
# macOS Homebrew Postgres: the superuser is usually your macOS login, not "postgres". Omit POSTGRES_USER to
# let settings use $USER, or set explicitly, e.g. POSTGRES_USER=yourname
# Docker / Linux with a postgres role: POSTGRES_USER=postgres
# POSTGRES_USER=postgres
# Empty password is typical for local trust auth; set for remote/Docker:
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Optional tuning
# POSTGRES_CONN_MAX_AGE=60
# POSTGRES_CONNECT_TIMEOUT=10
