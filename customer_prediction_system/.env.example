# Copy to .env and adjust. Django loads credentials via the environment (export or your process manager).

# Production (e.g. Render): set a strong secret; never commit it.
# DJANGO_SECRET_KEY=

# Omit locally for DEBUG=True, or set DEBUG=true explicitly. On Render, `RENDER` is set and DEBUG defaults to false.
# DEBUG=false

# Hosts / CSRF / CORS (production). Render sets RENDER_EXTERNAL_URL automatically; that hostname is used unless you override.
# ALLOWED_HOSTS=your-app.onrender.com,www.example.com
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://www.example.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com,https://your-app.onrender.com

# PostgreSQL — required. Used for django.contrib.auth, sessions, JWT blacklist, and predictor models.
# Example (local): DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/customer_prediction
DATABASE_URL=

# Optional connection tuning (defaults are fine for most deployments)
# DATABASE_CONN_MAX_AGE=600
# DATABASE_SSL_REQUIRE=true
